# Environment Variables for Smart Media System
# Copy this file to .env and fill in your values

# Database
MYSQL_URL=mysql+asyncmy://root:root123@localhost:3306/smart_media
REDIS_URL=redis://localhost:6379/0
MONGODB_URL=mongodb://localhost:27017

# JWT (CHANGE in production!)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Qwen AI (Required - get from Alibaba Cloud DashScope)
QWEN_API_KEY=
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1

# Crawler
HOT_CRAWL_INTERVAL_MINUTES=10

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# App
DEBUG=true
